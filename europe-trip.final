  <div class="city-header">
    <div>
      <div class="city-eyebrow c-brussels">Stop 03 · Belgium</div>
      <h2 class="city-name c-brussels">Brussels</h2>
      <div class="city-meta">
        <span>July 15–17</span><span class="city-sep">·</span>
        <span>2 nights</span><span class="city-sep">·</span>
        <span>Chocolate, Waffles & Grand Squares</span>
      </div>
    </div>
    <span class="city-tag" style="background:#2E7D5E">Belgium</span>
  </div>

  <div class="city-photo">
    <img src="https://images.unsplash.com/photo-1467269204594-9661b134dd2b?w=1200&q=80" crossorigin="anonymous" alt="Grand Place Brussels at night">
    <div class="city-photo-caption">Brussels's Grand-Place — often called the most beautiful town square in Europe</div>
  </div>

  <div class="accom-banner">
    <div class="accom-card">
      <div class="accom-icon">🏠</div>
      <div>
        <div class="accom-label">Airbnb · Brussels</div>
        <div class="accom-name">Appartement confortable</div>
        <div class="accom-address">Rue Bara 159, 1070 Anderlecht, Belgium · Host: Abdulwahab</div>
        <div class="accom-times">
          <div class="accom-time-block">
            <div class="accom-time-label">Check-in</div>
            <div class="accom-time-val">Wed, Jul 15</div>
            <div class="accom-time-sub">After 3:00 PM</div>
          </div>
          <div class="accom-time-block">
            <div class="accom-time-label">Checkout</div>
            <div class="accom-time-val">Fri, Jul 17</div>
            <div class="accom-time-sub">By 11:00 AM</div>
          </div>
        </div>
        <span class="accom-note lockbox">🔒 Self check-in — lockbox</span>
      </div>
